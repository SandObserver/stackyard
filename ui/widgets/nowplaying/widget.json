{
  "name": "nowplaying",
  "label": "Now Playing",
  "sizes": ["small"],
  "fields": [
    {
      "key": "provider",
      "type": "select",
      "variant": "pills",
      "label": "Media server",
      "options": [
        { "value": "plex", "label": "Plex" },
        { "value": "jellyfin", "label": "Jellyfin" },
        { "value": "emby", "label": "Emby" },
        { "value": "navidrome", "label": "Navidrome" }
      ]
    },

    { "key": "plexUrl", "type": "text", "label": "Plex server URL", "placeholder": "http://host:32400", "hint": "Your Plex Media Server (default port 32400) — not Tautulli.", "showIf": { "field": "provider", "equals": "plex" } },
    { "key": "plexToken", "type": "secret", "label": "Plex token (X-Plex-Token)", "showIf": { "field": "provider", "equals": "plex" } },

    { "key": "jellyfinUrl", "type": "text", "label": "Jellyfin URL", "placeholder": "http://host:8096", "showIf": { "field": "provider", "equals": "jellyfin" } },
    { "key": "jellyfinKey", "type": "secret", "label": "Jellyfin API key", "showIf": { "field": "provider", "equals": "jellyfin" } },

    { "key": "embyUrl", "type": "text", "label": "Emby URL", "placeholder": "http://host:8096", "showIf": { "field": "provider", "equals": "emby" } },
    { "key": "embyKey", "type": "secret", "label": "Emby API key", "showIf": { "field": "provider", "equals": "emby" } },

    { "key": "navidromeUrl", "type": "text", "label": "Navidrome URL", "placeholder": "http://host:4533", "showIf": { "field": "provider", "equals": "navidrome" } },
    { "key": "navidromeUser", "type": "text", "label": "Username", "showIf": { "field": "provider", "equals": "navidrome" } },
    { "key": "navidromePassword", "type": "secret", "label": "Password", "showIf": { "field": "provider", "equals": "navidrome" } },

    { "key": "href", "type": "text", "label": "Click URL (optional)", "placeholder": "https://…", "hint": "Opens when the widget is clicked.", "optional": true }
  ]
}
