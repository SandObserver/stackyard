{
  "name": "weather",
  "label": "Weather",
  "sizes": ["small"],
  "fields": [
    { "key": "cityQuery", "type": "text", "label": "Search", "placeholder": "e.g. Ottawa",
      "optional": true, "transient": true },

    { "key": "city", "type": "select", "label": "Location", "optionsFrom": "geocode",
      "carries": ["lat", "lon"],
      "hint": "Type a city above, then Fetch and pick the matching place." },

    { "key": "units", "type": "select", "variant": "pills", "label": "Units", "default": "c",
      "options": [
        { "value": "c", "label": "\u00b0C" },
        { "value": "f", "label": "\u00b0F" }
      ] },

    { "key": "feelsLike", "type": "toggle", "label": "Show feels like", "default": false },

    { "key": "href", "type": "text", "label": "Link URL", "placeholder": "https://\u2026",
      "hint": "Opens when the widget is clicked.", "optional": true }
  ]
}
